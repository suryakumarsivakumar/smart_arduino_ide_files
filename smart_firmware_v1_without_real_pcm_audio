// ---------- Root Endpoint ----------
void handleRoot()
{
    snprintf(
        jsonBuffer,
        sizeof(jsonBuffer),

        "{"
        "\"device\":\"%s\","
        "\"firmware\":\"%s\","
        "\"status\":\"Running\""
        "}",

        FW_NAME,
        FW_VERSION
    );

    server.send(200, "application/json", jsonBuffer);
}

// ---------- Health Endpoint ----------
void handleHealth()
{
    snprintf(
        jsonBuffer,
        sizeof(jsonBuffer),

        "{"
        "\"status\":\"OK\","
        "\"uptime\":%lu,"
        "\"wifiClients\":%d,"
        "\"batteryLow\":%s,"
        "\"batteryCritical\":%s,"
        "\"freeHeap\":%u"
        "}",

        millis() / 1000,
        WiFi.softAPgetStationNum(),
        battery.low ? "true" : "false",
        battery.critical ? "true" : "false",
        ESP.getFreeHeap()
    );

    server.send(200, "application/json", jsonBuffer);
}

// ---------- Main Data Endpoint ----------
void handleData()
{
    // Get the latest sensor values before sending
    updateAllFSR();

    snprintf(
        jsonBuffer,
        sizeof(jsonBuffer),

        "{"

        "\"battery\":{"
            "\"voltage\":%.2f,"
            "\"percent\":%u,"
            "\"low\":%s,"
            "\"critical\":%s"
        "},"

        "\"fsr1\":{"
            "\"value\":%d,"
            "\"state\":\"%s\","
            "\"pressed\":%s,"
            "\"click\":%s"
        "},"

        "\"fsr2\":{"
            "\"value\":%d,"
            "\"state\":\"%s\","
            "\"pressed\":%s,"
            "\"click\":%s"
        "},"

        "\"microphone\":{"
            "\"rms\":%.2f,"
            "\"peak\":%ld,"
            "\"voice\":%s"
        "},"

        "\"uptime\":%lu"

        "}",

        // Battery
        battery.voltage,
        battery.percent,
        battery.low ? "true" : "false",
        battery.critical ? "true" : "false",

        // FSR1
        fsr1.raw,
        pressStateToString(fsr1.state),
        isFSR1Pressed() ? "true" : "false",
        fsr1.click ? "true" : "false",

        // FSR2
        fsr2.raw,
        pressStateToString(fsr2.state),
        isFSR2Pressed() ? "true" : "false",
        fsr2.click ? "true" : "false",

        // Microphone
        microphone.rms,
        (long)microphonePeak(),
        microphone.voiceDetected ? "true" : "false",

        // Uptime
        millis() / 1000
    );

    server.send(200, "application/json", jsonBuffer);

    // Clear one-shot click events
    fsr1.click = false;
    fsr2.click = false;
}
// ---------- WiFi ----------
void initWiFi()
{
    Serial.println();
    Serial.println("=================================");
    Serial.println("Starting SMART Access Point");
    Serial.println("=================================");

    WiFi.mode(WIFI_AP);

    WiFi.softAP(
        WIFI_SSID,
        WIFI_PASSWORD
    );

    Serial.print("SSID : ");
    Serial.println(WIFI_SSID);

    Serial.print("Password : ");
    Serial.println(WIFI_PASSWORD);

    Serial.print("IP Address : ");
    Serial.println(WiFi.softAPIP());

    Serial.println();
}

// ---------- HTTP Server ----------
void initServer()
{
    server.on("/", handleRoot);

    server.on("/health", handleHealth);

    server.on("/data", handleData);

    server.begin();

    Serial.println("HTTP Server Started");
}

//
//==========================================================
// SETUP
//==========================================================
//

void setup()
{
    Serial.begin(115200);

    delay(2000);

    Serial.println();
    Serial.println("==================================================");
    Serial.println(" SMART Firmware v2.0");
    Serial.println(" Surgical Monitoring And Analytics In Real Time");
    Serial.println("==================================================");

    bootTime = millis();

    // Configure ADC
    analogReadResolution(12);

    // Battery ADC pin
    pinMode(PIN_BATTERY, INPUT);

    // Initialize FSRs
    initFSR();

    // Initialize Battery
    updateBattery();

    // Initialize Microphone
    initMicrophone();
    updateMicrophone();

    // Start WiFi
    initWiFi();

    // Start HTTP Server
    initServer();

    Serial.println();
    Serial.println("====================================");
    Serial.println(" SMART DEVICE READY");
    Serial.println("====================================");

    Serial.print("SSID : ");
    Serial.println(WIFI_SSID);

    Serial.print("IP   : ");
    Serial.println(WiFi.softAPIP());

    Serial.println();
}

//
//==========================================================
// LOOP
//==========================================================
//

void loop()
{
    // Always process HTTP requests
    server.handleClient();

    unsigned long now = millis();

    //--------------------------------------------------
    // FSR Update (20 ms)
    //--------------------------------------------------
    if (now - lastFSRUpdate >= 5)
    {
        lastFSRUpdate = now;

        updateAllFSR();
    }

    //--------------------------------------------------
    // Battery Update (1000 ms)
    //--------------------------------------------------
    if (now - lastBatteryUpdate >= 1000)
    {
        lastBatteryUpdate = now;

        updateBattery();
    }

    //--------------------------------------------------
    // Microphone Update (50 ms)
    //--------------------------------------------------
    if (now - lastMicUpdate >= 50)
    {
        lastMicUpdate = now;

        updateMicrophone();
    }

    //--------------------------------------------------
    // Serial Debug (2000 ms)
    //--------------------------------------------------
    if (now - lastDebugPrint >= 2000)
    {
        lastDebugPrint = now;

        Serial.println();
        Serial.println("========================================");
        Serial.println("SMART DEVICE STATUS");
        Serial.println("========================================");

        printFSRStatus();

        printBatteryStatus();

        printMicrophoneStatus();

        Serial.print("WiFi Clients : ");
        Serial.println(WiFi.softAPgetStationNum());

        Serial.print("Free Heap    : ");
        Serial.println(ESP.getFreeHeap());

        Serial.print("Uptime (s)   : ");
        Serial.println(now / 1000);

        Serial.println("========================================");
        Serial.println();
    }
}

