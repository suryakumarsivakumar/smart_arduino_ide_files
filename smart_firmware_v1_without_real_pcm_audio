    Serial.println("%");

    Serial.print("Low Battery     : ");
    Serial.println(battery.low ? "YES" : "NO");

    Serial.print("Critical        : ");
    Serial.println(battery.critical ? "YES" : "NO");

    Serial.println("--------------------------------");
}

