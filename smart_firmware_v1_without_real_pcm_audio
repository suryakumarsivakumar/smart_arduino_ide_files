// ---------- Read Battery Voltage ----------
float readBatteryVoltage()
{
    long adcSum = 0;

    for (uint8_t i = 0; i < BATTERY_SAMPLES; i++)
    {
        adcSum += analogRead(PIN_BATTERY);
        delay(2);
    }

    float adcValue = adcSum / (float)BATTERY_SAMPLES;

    return ((adcValue / ADC_MAX) *
            ADC_REFERENCE *
            BATTERY_DIVIDER);
}

// ---------- Battery Percentage ----------
uint8_t batteryPercentage(float voltage)
{
    if (voltage >= BATTERY_MAX)
        return 100;

    if (voltage <= BATTERY_MIN)
        return 0;

    return (uint8_t)(((voltage - BATTERY_MIN) /
            (BATTERY_MAX - BATTERY_MIN)) * 100.0f);
}

// ---------- Update Battery ----------
void updateBattery()
{
    battery.voltage = readBatteryVoltage();

    battery.percent = batteryPercentage(battery.voltage);

    battery.low = (battery.percent <= 20);

    battery.critical = (battery.percent <= 10);
}

// ---------- Debug ----------
void printBatteryStatus()
{
