// ---------- Initialize ----------
void initMicrophone()
{
    Serial.println();
    Serial.println("Initializing INMP441...");

    esp_err_t err;

    err = i2s_driver_install(
            I2S_PORT,
            &i2s_config,
            0,
            NULL);

    if (err != ESP_OK)
    {
        Serial.printf("Driver Install Failed : %d\n", err);
        while (true);
    }

    err = i2s_set_pin(
            I2S_PORT,
            &pin_config);

    if (err != ESP_OK)
    {
        Serial.printf("Pin Config Failed : %d\n", err);
        while (true);
    }

    i2s_zero_dma_buffer(I2S_PORT);

    Serial.println("Microphone Ready");
}

// ---------- Capture ----------
bool captureMicrophone()
{
    size_t bytesRead = 0;

    esp_err_t err =
        i2s_read(
            I2S_PORT,
            micBuffer,
            sizeof(micBuffer),
            &bytesRead,
            pdMS_TO_TICKS(100));

    if (err != ESP_OK)
        return false;

    if (bytesRead == 0)
        return false;

    int samples = bytesRead / sizeof(int32_t);

    for (int i = 0; i < samples; i++)
    {
        // Convert 32-bit I2S to 24-bit sample
        micBuffer[i] >>= 8;
    }

    return true;
}

// ---------- Analyze ----------
void analyzeMicrophone()
{
    microphone.minimum = INT32_MAX;
    microphone.maximum = INT32_MIN;

    double sumSquares = 0;

    for (int i = 0; i < BUFFER_SAMPLES; i++)
    {
        int32_t sample = micBuffer[i];

        if (sample < microphone.minimum)
            microphone.minimum = sample;

        if (sample > microphone.maximum)
            microphone.maximum = sample;

        sumSquares +=
            (double)sample * (double)sample;
    }

    microphone.rms =
        sqrt(sumSquares / BUFFER_SAMPLES);

    microphone.voiceDetected =
        (microphone.rms >= MIC_RMS_THRESHOLD);
}

// ---------- Update ----------
void updateMicrophone()
{
    if (captureMicrophone())
    {
        analyzeMicrophone();
    }
}

// ---------- Peak ----------
int32_t microphonePeak()
{
    return microphone.maximum -
           microphone.minimum;
}

// ---------- Debug ----------
void printMicrophoneStatus()
{
    Serial.println("--------------------------------");

    Serial.print("Minimum : ");
    Serial.println(microphone.minimum);

    Serial.print("Maximum : ");
    Serial.println(microphone.maximum);

    Serial.print("Peak    : ");
    Serial.println(microphonePeak());

    Serial.print("RMS     : ");
    Serial.println(microphone.rms);

    Serial.print("Voice   : ");
    Serial.println(
        microphone.voiceDetected ?
        "YES" :
        "NO");

    Serial.println("--------------------------------");
}

