// FSR ENGINE (NEW)
//==========================================================

// Read one ADC sample
int readFSR(uint8_t pin)
{
    int sum = 0;

    for(int i = 0; i < 3; i++)
    {
        sum += analogRead(pin);
        delay(1);
    }

    return sum / 3;
}

//----------------------------------------------------------

PressState detectPress(int force)
{
    if(force < NOISE_THRESHOLD)
        return NO_PRESS;

    if(force < LIGHT_THRESHOLD)
        return LIGHT_CONTACT;

    if(force < HARD_THRESHOLD)
        return SOFT_PRESS;

    return HARD_PRESS;
}

//----------------------------------------------------------

void calibrateFSR(FSRSensor &sensor)
{
    long sum = 0;

    Serial.print("Calibrating GPIO ");
    Serial.println(sensor.pin);

    delay(3000);

    for(int i = 0; i < BASELINE_SAMPLES; i++)
    {
        int val = readFSR(sensor.pin);


        sum += val;

        delay(10);
    }

    sensor.baseline = sum / BASELINE_SAMPLES;

    Serial.print("Baseline = ");
    Serial.println(sensor.baseline);

    sensor.raw = sensor.baseline;
    sensor.force = 0;
    sensor.state = NO_PRESS;
    sensor.pressed = false;
    sensor.lastPressed = false;
    sensor.click = false;
}
//----------------------------------------------------------

void initFSR()
{
    pinMode(PIN_FSR1, INPUT);

    pinMode(PIN_FSR2, INPUT);

    Serial.println();
    Serial.println("==============================");
    Serial.println("FSR Calibration");
    Serial.println("==============================");

    calibrateFSR(fsr1);

    calibrateFSR(fsr2);

    Serial.println();

    Serial.println("Calibration Complete");

    Serial.println();
}

//----------------------------------------------------------

void updateFSR(FSRSensor &sensor)
{
    sensor.raw = readFSR(sensor.pin);

    if(sensor.raw > 3800)
        sensor.raw = 3800;

    int diff = sensor.raw - sensor.baseline;

    if(diff < 0)
        diff = 0;

    sensor.force = diff;

    sensor.state = detectPress(sensor.force);

    sensor.click = false;

    if(sensor.state == HARD_PRESS && !sensor.lastPressed)
    {
        sensor.click = true;
        sensor.lastPressed = true;
    }

    if(sensor.state == NO_PRESS)
    {
        sensor.lastPressed = false;
    }

    sensor.pressed = (sensor.state != NO_PRESS);
}

//----------------------------------------------------------

void updateAllFSR()
{
    updateFSR(fsr1);

    updateFSR(fsr2);
}

