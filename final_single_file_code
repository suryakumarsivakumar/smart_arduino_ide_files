//
//==========================================================
// HTTP: /pcm handler (UNCHANGED from base firmware)
//==========================================================
//

int16_t httpSendBuffer[MAX_PACKET_SAMPLES];

void handlePCM()
{
    uint32_t now = millis();
    lastRequestGapMs = now - lastRequestMillis;
    lastRequestMillis = now;

    server.client().setNoDelay(true);

    size_t waited = 0;
    size_t available = ringBufferAvailable(&audioRing);

    while (available < MIN_PACKET_SAMPLES && waited < HTTP_MAX_WAIT_MS)
    {
        delay(HTTP_WAIT_STEP_MS);
        waited += HTTP_WAIT_STEP_MS;
        available = ringBufferAvailable(&audioRing);
    }

    lastFillAtRequest = available;

    size_t toRequest = (available < MAX_PACKET_SAMPLES) ? available : MAX_PACKET_SAMPLES;
    size_t samplesCopied = ringBufferRead(&audioRing, httpSendBuffer, toRequest);

    lastPacketSamples = samplesCopied;

    if (samplesCopied == 0)
    {
        server.send(503, "text/plain", "No Audio Available Yet");
        return;
    }

    server.sendHeader("Cache-Control", "no-cache");
    server.sendHeader("Access-Control-Allow-Origin", "*");

    server.send_P(
        200,
        "application/octet-stream",
        (const char*)httpSendBuffer,
        samplesCopied * sizeof(int16_t)
    );
}

