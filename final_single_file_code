    Serial.println("INMP441 Initialized Successfully");
    Serial.println();
}

//
//==========================================================
// Continuous Audio Capture Task (UNCHANGED from base firmware)
//==========================================================
//

void audioCaptureTask(void* parameter)
{
    audioTaskRunning = true;

    Serial.println("Audio Capture Task Started");

    while (true)
    {
        size_t bytesRead = 0;

        esp_err_t err =
            i2s_read(I2S_PORT, rawBuffer, sizeof(rawBuffer), &bytesRead, portMAX_DELAY);

        if (err != ESP_OK)
        {
            Serial.print("I2S Read Error : ");
            Serial.println(err);
            continue;
        }

        if (bytesRead == 0)
        {
            continue;
        }

        int samples = bytesRead / sizeof(int32_t);
        if (samples > BUFFER_SAMPLES) samples = BUFFER_SAMPLES;

        for (int i = 0; i < samples; i++)
        {
            pcmBuffer[i] = rawBuffer[i] >> 14;
        }

        ringBufferWrite(&audioRing, pcmBuffer, samples);

        totalBytesCaptured += (samples * sizeof(int16_t));
        lastCaptureMillis = millis();

        analyzeAudio();
    }
}

void startAudioTask()
{
    xTaskCreate(
        audioCaptureTask,
        "AudioCaptureTask",
        4096,
        NULL,
        3,
        &audioTaskHandle);
}

