    Serial.begin(115200);
    delay(2000);

    Serial.println();
    Serial.println("==================================================");
    Serial.println(" SMART Firmware - Integrated Build");
    Serial.println(" Surgical Monitoring And Analytics In Real Time");
    Serial.println("==================================================");

    bootTime = millis();

    // Ring buffer must exist before the audio task starts writing to it.
    ringBufferInit(&audioRing, ringStorage, RING_BUFFER_SAMPLES);

    // ADC setup needed by FSR + battery reads.
    analogReadResolution(12);
    pinMode(PIN_BATTERY, INPUT);

    initMicrophone();

    startAudioTask();

    initFSR();

    updateBattery();

    initWiFi();

    initServer();

    Serial.println();
    Serial.println("====================================");
    Serial.println(" SMART DEVICE READY");
    Serial.println("====================================");

    Serial.print("SSID : ");
    Serial.println(WIFI_SSID);

    Serial.print("IP   : ");
    Serial.println(WiFi.softAPIP());

    Serial.println();
}

//
//==========================================================
// LOOP
//==========================================================
//
// server.handleClient() -> updateAllFSR() (5ms) ->
// updateBattery() (1000ms) -> printDebugStatus()/
// printFSRStatus()/printBatteryStatus() (2000ms)
//
// NOTE: there is intentionally NO microphone update here -
// audio capture runs entirely inside audioCaptureTask().
//

void loop()
{
    server.handleClient();

    unsigned long now = millis();

    //--------------------------------------------------
    // FSR Update (5 ms)
    //--------------------------------------------------
    if (now - lastFSRUpdate >= 5)
    {
        lastFSRUpdate = now;
        updateAllFSR();
    }

    //--------------------------------------------------
    // Battery Update (1000 ms)
    //--------------------------------------------------
    if (now - lastBatteryUpdate >= 1000)
    {
        lastBatteryUpdate = now;
        updateBattery();
    }

    //--------------------------------------------------
    // Debug Print (2000 ms): audio, then FSR, then battery
    //--------------------------------------------------
    if (now - lastDebugPrintMs >= DEBUG_PRINT_INTERVAL_MS)
    {
        lastDebugPrintMs = now;

        printDebugStatus();
        printFSRStatus();
        printBatteryStatus();

        Serial.print("WiFi Clients : ");
        Serial.println(WiFi.softAPgetStationNum());

        Serial.print("Free Heap    : ");
        Serial.println(ESP.getFreeHeap());

        Serial.print("Uptime (s)   : ");
        Serial.println(now / 1000);
    }
}
