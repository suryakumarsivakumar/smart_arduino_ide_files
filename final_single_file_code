//
//==========================================================
// Analyze Audio (UNCHANGED from base firmware)
//==========================================================
//

void analyzeAudio()
{
    sampleMin = 32767;
    sampleMax = -32768;

    long long sumSquares = 0;

    for (int i = 0; i < BUFFER_SAMPLES; i++)
    {
        int16_t sample = pcmBuffer[i];

        if (sample < sampleMin) sampleMin = sample;
        if (sample > sampleMax) sampleMax = sample;

        sumSquares += (long long)sample * (long long)sample;
    }

    peakValue = sampleMax - sampleMin;
    rmsValue = sqrt((double)sumSquares / BUFFER_SAMPLES);
}

